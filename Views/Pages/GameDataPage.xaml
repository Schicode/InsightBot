<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InsightBot.Views.Pages.GameDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:InsightBot.Views.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24" RowSpacing="16">

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Game Data (Media.pk2)"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <!-- PK2 loader card -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12" Padding="20">

                <!-- Path row -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             PlaceholderText="Path to Media.pk2…"
                             Text="{x:Bind VM.Pk2Path, Mode=TwoWay}"
                             IsReadOnly="False" />
                    <Button Grid.Column="1"
                            Content="Browse…"
                            Click="BrowseButton_Click" />
                    <Button Grid.Column="2"
                            Content="Load"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind VM.LoadCommand}" />
                </Grid>

                <!-- Status + progress -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind VM.IsLoading, Mode=OneWay}"
                                  Width="20" Height="20" />
                    <TextBlock Text="{x:Bind VM.StatusText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Search + results -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="12">

                <!-- Tab selector -->
                <TabView Grid.Row="0"
                         SelectedIndex="{x:Bind VM.TabIndex, Mode=TwoWay}"
                         IsAddTabButtonVisible="False"
                         TabWidthMode="Equal">
                    <TabViewItem Header="Monsters" IsClosable="False" />
                    <TabViewItem Header="Items"    IsClosable="False" />
                    <TabViewItem Header="Skills"   IsClosable="False" />
                </TabView>

                <!-- Search box -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             PlaceholderText="Search by name or RefId…"
                             Text="{x:Bind VM.SearchQuery, Mode=TwoWay}" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{x:Bind VM.ClearCommand}" />
                </Grid>

                <!-- Results -->
                <ListView Grid.Row="2"
                          ItemsSource="{x:Bind VM.Results, Mode=OneWay}"
                          SelectionMode="Single">
                    <ListView.Header>
                        <Grid ColumnDefinitions="100,200,220,*" Padding="12,6"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <TextBlock Grid.Column="0" Text="RefId"        FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Display Name" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Internal Name" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Info"         FontWeight="SemiBold" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameDataRow">
                            <Grid ColumnDefinitions="100,200,220,*" Padding="12,4">
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind RefId}"
                                           FontFamily="Consolas"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind InternalName}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind Info}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </Grid>
        </Border>

    </Grid>
</Page>
