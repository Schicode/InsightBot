<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InsightBot.Views.Pages.BuffsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="using:InsightBot.Views.Pages"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="700">

            <TextBlock Text="Buffs &amp; Skills" Style="{StaticResource TitleTextBlockStyle}" />

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16" Padding="20">

                    <ToggleSwitch Header="Enable Buff Rotation"
                                  IsOn="{x:Bind VM.Buffs.Enabled, Mode=TwoWay}" />

                    <!-- Self-buff skill IDs -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Self-Buff Skill IDs (hex, comma-separated)" />
                        <TextBox Text="{x:Bind VM.SelfBuffSkillIdsText, Mode=TwoWay}"
                                 PlaceholderText="0x1000,0x1001" />
                    </StackPanel>

                    <!-- Heal -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Heal Skill ID (hex)" />
                        <TextBox Text="{x:Bind VM.HealSkillIdText, Mode=TwoWay}"
                                 PlaceholderText="0x0000" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Heal below HP (%)" />
                        <Slider x:Name="HealSlider"
                                Minimum="10" Maximum="90" StepFrequency="5"
                                Value="{x:Bind VM.Buffs.HealThreshold, Mode=TwoWay}" />
                        <TextBlock Text="{x:Bind HealSlider.Value, Mode=OneWay}" />
                    </StackPanel>

                    <!-- MP -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="MP Restore Skill ID (hex)" />
                        <TextBox Text="{x:Bind VM.MpSkillIdText, Mode=TwoWay}"
                                 PlaceholderText="0x0000" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Restore below MP (%)" />
                        <Slider x:Name="MpSlider"
                                Minimum="10" Maximum="90" StepFrequency="5"
                                Value="{x:Bind VM.Buffs.MpThreshold, Mode=TwoWay}" />
                        <TextBlock Text="{x:Bind MpSlider.Value, Mode=OneWay}" />
                    </StackPanel>

                    <!-- Skill delay -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Skill Cast Delay (ms)" />
                        <NumberBox Value="{x:Bind VM.Buffs.SkillDelayMs, Mode=TwoWay}"
                                   Minimum="100" Maximum="3000" SpinButtonPlacementMode="Inline" />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
