<Page
    x:Class="InsightBot.Views.Pages.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InsightBot.Views.Pages"
    xmlns:vm="using:InsightBot.Views.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Skill &amp; Buff Selection"
                   Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,4"/>

        <!-- Search + Load bar -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     PlaceholderText="Search skills…"
                     Text="{x:Bind VM.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <ToggleButton Grid.Column="1"
                          Content="Selected only"
                          IsChecked="{x:Bind VM.ShowActiveOnly, Mode=TwoWay}"/>

            <Button Grid.Column="2"
                    Content="⟳ Reload from PK2"
                    Command="{x:Bind VM.LoadSkillsCommand}"/>

            <ProgressRing Grid.Column="3"
                          IsActive="{x:Bind VM.IsLoading, Mode=OneWay}"
                          Width="24" Height="24"/>
        </Grid>

        <!-- Dual-panel layout -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Available Skills -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Available Skills"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <GridView Grid.Row="1"
                              x:Name="AvailableGrid"
                              ItemsSource="{x:Bind VM.AvailableSkills, Mode=OneWay}"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="AvailableItem_Click">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SkillIconItem">
                                <Border Width="80" Height="90" CornerRadius="6"
                                        Margin="4" Padding="4"
                                        Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"
                                        ToolTipService.ToolTip="{x:Bind Tooltip}">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <!-- Icon or placeholder -->
                                        <Grid Width="48" Height="48">
                                            <Image Source="{x:Bind Icon, Mode=OneWay}"
                                                   Width="48" Height="48"
                                                   Stretch="UniformToFill"/>
                                            <!-- Fallback placeholder when Icon is null -->
                                            <TextBlock Text="⚔" FontSize="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{x:Bind Icon, Converter={StaticResource NullToVisConverter}, Mode=OneWay}"/>
                                        </Grid>
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   TextAlignment="Center"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </Border>

            <!-- Centre: arrow buttons -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="12">
                <Button x:Name="AddButton"
                        Content="▶"
                        Width="40" Height="40"
                        Click="AddButton_Click"
                        ToolTipService.ToolTip="Add selected skill"/>
                <Button x:Name="RemoveButton"
                        Content="◀"
                        Width="40" Height="40"
                        Click="RemoveButton_Click"
                        ToolTipService.ToolTip="Remove selected skill"/>
            </StackPanel>

            <!-- Right: Selected Skills -->
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SubtitleTextBlockStyle}">
                        <Run Text="Selected Skills ("/>
                        <Run Text="{x:Bind VM.SelectedSkills.Count, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>

                    <GridView Grid.Row="1"
                              x:Name="SelectedGrid"
                              ItemsSource="{x:Bind VM.SelectedSkills, Mode=OneWay}"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="SelectedItem_Click">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SkillIconItem">
                                <Border Width="80" Height="90" CornerRadius="6"
                                        Margin="4" Padding="4"
                                        Background="{ThemeResource AccentFillColorSelectedTextBackgroundBrush}"
                                        ToolTipService.ToolTip="{x:Bind Tooltip}">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <Grid Width="48" Height="48">
                                            <Image Source="{x:Bind Icon, Mode=OneWay}"
                                                   Width="48" Height="48"
                                                   Stretch="UniformToFill"/>
                                            <TextBlock Text="⚔" FontSize="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{x:Bind Icon, Converter={StaticResource NullToVisConverter}, Mode=OneWay}"/>
                                        </Grid>
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   TextAlignment="Center"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <Button Grid.Row="2"
                            Content="Clear all"
                            HorizontalAlignment="Right"
                            Click="ClearAll_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="3"
                   Text="{x:Bind VM.StatusText, Mode=OneWay}"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Grid>
</Page>
