<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InsightBot.Views.Pages.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowDefinitions="Auto,*,Auto">

        <TextBlock Grid.Row="0"
                   Text="Log" Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1"
                      x:Name="LogScroll"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind VM.LogLines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Clear Log"
                Margin="0,12,0,0"
                Command="{x:Bind VM.ClearLogCommand}" />

    </Grid>
</Page>
